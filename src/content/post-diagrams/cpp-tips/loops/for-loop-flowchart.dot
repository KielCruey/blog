digraph g {
    // nodes
    start [label="Start", shape=doublecircle];
    init [label="Initialization of Expression", shape=box];
    test [label="Test Condition", shape=diamond];
    subgraph{
        rank=same;
        
        update [label="Update Expression Statement", shape=box];
        loop [label="Loop Execution", shape=box];
    }

    stop [label="Stop", shape=doublecircle]

    // arrows
    start -> init 
    init -> test
    test:w -> loop[label="True"] 
    loop -> update
    update -> test
    test:e -> stop[label="False" ]
}